import discord
from discord.ext import commands
intents = discord.Intents.default()
bot = commands.Bot( command_prefix="$",intents=intents)
@bot.event
async def on_ready():
    print(f'Hemos iniciado sesión como {bot.user}')
@bot.command()
async def hola(ctx):
    await ctx.send("Hola, aquí vas a aprender como cuidar el planeta reduciendo resudios. Puede ser en la casa, en el trabajo,etc")
@bot.command()
async def habito(ctx):
    await ctx.send("Tu ayudas el planeta si tu usas bolsas de tela")

